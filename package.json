{
  "name": "multisystem",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:hub": "pnpm --filter @multisystem/ui build && turbo run dev --filter=@multisystem/api --filter=@multisystem/hub",
    "build": "turbo run build",
    "build:hub": "turbo run build --filter=@multisystem/ui --filter=@multisystem/hub",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck --continue"
  },
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  }
}
