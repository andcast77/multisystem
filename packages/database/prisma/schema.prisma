// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../dist/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Configuración de seed
// Ejecutar con: pnpm prisma db seed

// ========================================
// ENUMS COMPARTIDOS
// ========================================

/// Rol a nivel plataforma/legacy (Shopflow). Para control por empresa usar MembershipRole en CompanyMember.
enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

/// Rol de pertenencia a una empresa: owner (registrante), admin de empresa, o usuario estándar.
enum MembershipRole {
  OWNER   // Registrante; control total (eliminar empresa, transferir ownership)
  ADMIN   // Admin de empresa; no puede eliminar empresa ni transferir ownership
  USER    // Usuario estándar de la empresa
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CHECK
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  LOW_STOCK
  IMPORTANT_SALE
  PENDING_TASK
  SYSTEM
  COLLAB
  SECURITY
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

// ========================================
// ENUMS WORKIFY
// ========================================

enum SalaryType {
  HOUR
  DAY
  WEEK
  BIWEEK
  MONTH
}

enum OvertimeType {
  MULTIPLIER
  FIXED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PayrollStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LicenseType {
  VACATION
  SICK_LEAVE
  PERSONAL_LEAVE
  UNPAID_LEAVE
  OTHER
}

enum LicenseStatus {
  PENDING
  APPROVED
  REJECTED
}

// ========================================
// ENUMS SHOPFLOW
// ========================================

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum LoyaltyPointType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  VIEW
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  OTHER
  PRINT
}

enum EntityType {
  PRODUCT
  CATEGORY
  SUPPLIER
  CUSTOMER
  SALE
  USER
  STORE
  STORE_CONFIG
  TICKET_CONFIG
  COMPANY
  OTHER
  INVENTORY_TRANSFER
}

enum TicketType {
  TICKET
  INVOICE
  RECEIPT
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ServiceVisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ========================================
// MODELOS COMPARTIDOS
// ========================================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  role              UserRole @default(USER)
  isActive          Boolean  @default(true)
  /// Superusuario: puede acceder a cualquier empresa sin ser miembro. No es usuario de empresa.
  isSuperuser       Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  // Email verification
  emailVerified     Boolean  @default(false)
  verificationTokenHash String?  @unique
  verificationTokenExpiry DateTime?
  // Password reset
  passwordResetTokenHash String? @unique
  passwordResetTokenExpiry DateTime?
  /// Empresa preferida/por defecto en Shopflow; se asigna automáticamente si es null (primera por nombre).
  shopflowPreferredCompanyId String?
  /// Timestamp de aceptación explícita de la política de privacidad (GDPR Art. 7 / LFPDPPP).
  privacyAcceptedAt DateTime?
  /// Intentos fallidos de contraseña consecutivos (PLAN-26 lockout).
  failedLoginAttempts Int      @default(0)
  /// Cuenta bloqueada hasta este instante (null = no bloqueada).
  lockedUntil         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Empresas que posee (registrante / owner)
  companiesOwned    Company[]       @relation("CompanyOwner")
  shopflowPreferredCompany Company?  @relation("ShopflowPreferredCompany", fields: [shopflowPreferredCompanyId], references: [id], onDelete: SetNull)
  // Pertenencia a empresas (owner/admin/user por empresa)
  companyMemberships CompanyMember[]

  // Relaciones Workify
  userRoles         UserRoleAssignment[]
  userPermissions   UserPermission[]
  employees         Employee[]
  workOrdersCreated WorkOrder[] @relation("WorkOrderCreatedBy")
  invoicesCreated   Invoice[]   @relation("InvoiceCreatedBy")

  // Relaciones Shopflow
  sales             Sale[]
  actionHistory      ActionHistory[]
  notifications     Notification[]
  userPreferences   UserPreferences[]
  notificationPreferences NotificationPreference?
  inventoryTransfers InventoryTransfer[]
  userStores        UserStore[]
  pushSubscriptions PushSubscription[]
  sessions         Session[]
  mfaBackupCodes   MfaBackupCode[]

  @@map("users")
}

/// One-time recovery codes for TOTP MFA (hashed at rest).
model MfaBackupCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_backup_codes")
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  /// Hash SHA-256 del refresh opaco (web) o token legado (p. ej. JWT en Shopflow).
  sessionToken String    @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  /// Última actividad autenticada (actualización acotada en `requireAuth`).
  lastSeenAt   DateTime?
  /// Último `jti` del access JWT asociado a esta sesión (revocación / blacklist).
  accessJti    String?
  /// Contexto de empresa rehidratado en refresh (no sustituye validación en cada request).
  companyId         String?
  membershipRole    String?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

// ========================================
// MODELOS WORKIFY
// ========================================

model Company {
  id          String   @id @default(uuid())
  name        String   @unique
  parentId    String?
  /// Usuario que registró la empresa (owner). No es un "usuario de empresa" normal.
  ownerUserId String?
  isActive    Boolean  @default(true)
  /// Logo de la empresa (URL o path)
  logo        String?
  /// RFC o número de identificación fiscal
  taxId       String?
  /// Dirección de la empresa
  address     String?
  /// Teléfono de contacto
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Owner (registrante)
  owner       User?    @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  // Miembros de la empresa (owner, admin, user)
  members     CompanyMember[]

  // Relaciones jerárquicas
  parent      Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children    Company[] @relation("CompanyHierarchy")

  // Relaciones
  departments      Department[]
  roles            Role[]
  employees        Employee[]
  payrolls         Payroll[]
  documents        Document[]
  reports          Report[]
  auditLogs        AuditLog[]
  holidays         Holiday[]
  workShifts       WorkShift[]
  userRoleAssignments UserRoleAssignment[]
  timeEntries      TimeEntry[]
  licensePolicies  LicensePolicy[]
  integrationLogs  IntegrationLog[]
  notifications    Notification[]
  technicalAssets  TechnicalAsset[]
  workOrders       WorkOrder[]
  serviceVisits    ServiceVisit[]

  payrollRules     PayrollRule[]
  licenses         License[]
  schedules        Schedule[]
  specialDayAssignments SpecialDayAssignment[]
  workOrderParts   WorkOrderPart[]

  // Módulos contratados por la empresa
  companyModules   CompanyModule[]

  // Permisos directos por empresa (overrides)
  userPermissions  UserPermission[]

  // Shopflow
  products          Product[]
  categories        Category[]
  suppliers         Supplier[]
  customers        Customer[]
  sales             Sale[]
  invoices          Invoice[]
  storeConfigs      StoreConfig[]
  ticketConfigs     TicketConfig[]
  inventoryTransfers InventoryTransfer[]
  loyaltyConfigs    LoyaltyConfig[]
  loyaltyPoints     LoyaltyPoint[]
  actionHistories   ActionHistory[]
  stores            Store[]
  storeInventory    StoreInventory[]
  userPreferences   UserPreferences[]
  usersWithPreferredShopflow User[] @relation("ShopflowPreferredCompany")

  @@map("companies")
}

/// Pertenencia de un usuario a una empresa con rol: owner (registrante), admin o user.
/// El superuser no tiene filas aquí. El owner tiene una fila con OWNER; admins y usuarios con ADMIN/USER.
model CompanyMember {
  id             String         @id @default(uuid())
  userId         String
  companyId      String
  membershipRole MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

   // Módulos activos para este miembro dentro de la empresa
   modules        CompanyMemberModule[]

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("company_members")
}

/// Catálogo global de módulos (Workify, Shopflow, Techservices, etc.)
model Module {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  companyModules CompanyModule[]
  memberModules  CompanyMemberModule[]

  @@map("modules")
}

/// Catálogo global de unidades de medida para productos (compartido entre empresas).
model Unit {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  symbol    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@map("units")
}

/// Relación empresa ↔ módulo: define qué módulos tiene contratados/habilitados una empresa.
model CompanyModule {
  id        String   @id @default(uuid())
  companyId String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@index([companyId])
  @@map("company_modules")
}

/// Relación miembro de empresa ↔ módulo: módulos activos para cada usuario dentro de su empresa.
model CompanyMemberModule {
  id              String   @id @default(uuid())
  companyMemberId String
  moduleId        String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  companyMember   CompanyMember @relation(fields: [companyMemberId], references: [id], onDelete: Cascade)
  module          Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([companyMemberId, moduleId])
  @@map("company_member_modules")
}

model Department {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones jerárquicas
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")

  // Relaciones
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]
  positions   Position[]

  @@index([companyId])
  @@map("departments")
}

model Position {
  id                    String      @id @default(uuid())
  name                  String
  description           String?
  departmentId          String
  salaryType            SalaryType @default(MONTH)
  baseSalary            Decimal?    @db.Decimal(10, 2)
  overtimeType          OvertimeType?
  overtimeMultiplier    Decimal?    @db.Decimal(5, 2)
  overtimeFixedAmount   Decimal?    @db.Decimal(10, 2)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relaciones
  department            Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employees             Employee[]

  @@map("positions")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones jerárquicas
  parent      Role?    @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    Role[]   @relation("RoleHierarchy")

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles   UserRoleAssignment[]
  permissions RolePermission[]

  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  // Relaciones
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@map("user_roles")
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  companyId    String?
  createdAt    DateTime @default(now())

  // Relaciones
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, companyId])
  @@map("user_permissions")
}

model Employee {
  id                      String          @id @default(uuid())
  companyId              String
  departmentId           String?
  positionId             String?
  userId                 String?
  idNumber               String?
  idNumberHash           String?
  firstName              String
  lastName               String
  birthDate              DateTime?
  gender                 Gender?
  dateJoined             DateTime        @default(now())
  status                 EmployeeStatus  @default(ACTIVE)
  customSalaryAmount     Decimal?       @db.Decimal(10, 2)
  customSalaryType       SalaryType?
  customOvertimeEligible Boolean        @default(false)
  isDeleted              Boolean        @default(false)
  deletedAt              DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  // Relaciones
  company                Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department             Department?    @relation(fields: [departmentId], references: [id])
  position               Position?       @relation(fields: [positionId], references: [id])
  user                   User?           @relation(fields: [userId], references: [id])
  timeEntries            TimeEntry[]
  schedules              Schedule[]
  specialDayAssignments  SpecialDayAssignment[]
  payrolls              Payroll[]
  licenses              License[]
  documents             Document[]
  assignedWorkOrders    WorkOrder[]
  serviceVisits         ServiceVisit[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([departmentId])
  @@index([companyId, idNumberHash])
  @@map("employees")
}

model WorkShift {
  id          String   @id @default(uuid())
  name        String
  description String?
  startTime   String   // Formato HH:mm
  endTime     String   // Formato HH:mm
  breakStart  String?  // Formato HH:mm
  breakEnd    String?  // Formato HH:mm
  tolerance   Int      @default(15) // minutos
  isActive    Boolean  @default(true)
  isNightShift Boolean @default(false)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedules            Schedule[]
  specialDayAssignments SpecialDayAssignment[]

  @@index([companyId])
  @@map("work_shifts")
}

model Schedule {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  workShiftId String
  dayOfWeek   Int      // 0 = Domingo, 6 = Sábado
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workShift   WorkShift @relation(fields: [workShiftId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workShiftId, dayOfWeek])
  @@index([companyId])
  @@map("schedules")
}

model SpecialDayAssignment {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  workShiftId String
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workShift   WorkShift @relation(fields: [workShiftId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("special_day_assignments")
}

model Holiday {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  isRecurring Boolean  @default(false)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@map("holidays")
}

model TimeEntry {
  id          String   @id @default(uuid())
  employeeId  String
  companyId   String
  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?
  breakStart  DateTime?
  breakEnd    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([employeeId, date])
  @@map("time_entries")
}

model Payroll {
  id          String        @id @default(uuid())
  employeeId  String
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  grossSalary Decimal      @db.Decimal(10, 2)
  deductions  Decimal      @db.Decimal(10, 2) @default(0)
  netSalary   Decimal      @db.Decimal(10, 2)
  status      PayrollStatus @default(PENDING)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relaciones
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@map("payrolls")
}

model PayrollRule {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  ruleType    String   // Ej: "OVERTIME", "BONUS", "DEDUCTION"
  formula     String   // Fórmula de cálculo
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("payroll_rules")
}

model License {
  id          String        @id @default(uuid())
  companyId   String
  employeeId  String
  type        LicenseType
  startDate   DateTime
  endDate     DateTime
  status      LicenseStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relaciones
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@map("licenses")
}

model LicensePolicy {
  id          String   @id @default(uuid())
  companyId   String
  type        LicenseType
  daysPerYear Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("license_policies")
}

model Document {
  id          String   @id @default(uuid())
  employeeId  String?
  companyId   String
  name        String
  type        String
  fileUrl     String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("documents")
}

model AuditLog {
  id          String   @id @default(uuid())
  /// Null for platform-wide security events (e.g. failed login with no resolved tenant).
  companyId   String?
  userId      String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // Relaciones
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model IntegrationLog {
  id          String   @id @default(uuid())
  companyId   String
  integration String
  request     Json?
  response    Json?
  status      String
  error       String?
  createdAt   DateTime @default(now())

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("integration_logs")
}

model Report {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  type        String
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Translation {
  id          String   @id @default(uuid())
  key         String
  language    String
  value       String
  module      String?  // "workify", "shopflow", "shared"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, language, module])
  @@map("translations")
}

model TechnicalAsset {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  brand         String?
  model         String?
  serialNumber  String?
  customerName  String?
  customerEmail String?
  customerPhone String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrders    WorkOrder[]

  @@map("technical_assets")
}

model WorkOrder {
  id                 String            @id @default(uuid())
  companyId          String
  assetId            String?
  createdByUserId    String
  assignedEmployeeId String?
  title              String
  description        String?
  status             WorkOrderStatus   @default(OPEN)
  priority           WorkOrderPriority @default(MEDIUM)
  requestedAt        DateTime          @default(now())
  dueAt              DateTime?
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relaciones
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  asset              TechnicalAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdByUser      User            @relation("WorkOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedEmployee   Employee?       @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  parts              WorkOrderPart[]
  visits             ServiceVisit[]

  @@index([companyId, status])
  @@map("work_orders")
}

model WorkOrderPart {
  id          String   @id @default(uuid())
  companyId   String
  workOrderId String
  name        String
  quantity    Int      @default(1)
  unitCost    Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("work_order_parts")
}

model ServiceVisit {
  id                 String             @id @default(uuid())
  companyId           String
  workOrderId        String
  assignedEmployeeId String?
  scheduledStartAt   DateTime
  scheduledEndAt     DateTime?
  status             ServiceVisitStatus @default(SCHEDULED)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relaciones
  company            Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrder           WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assignedEmployee    Employee?  @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  @@index([workOrderId, status])
  @@map("service_visits")
}

// ========================================
// MODELOS SHOPFLOW
// ========================================

model Product {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  sku         String?
  barcode     String?
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2)
  categoryId  String?
  supplierId  String?
  unitId      String?
  active      Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         Category?           @relation(fields: [categoryId], references: [id])
  supplier         Supplier?           @relation(fields: [supplierId], references: [id])
  unit             Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  saleItems        SaleItem[]
  inventoryTransfers InventoryTransfer[]
  storeInventory   StoreInventory[]

  @@unique([companyId, sku])
  @@unique([id, companyId])
  @@index([companyId])
  @@index([companyId, barcode])
  @@index([categoryId])
  @@index([unitId])
  @@map("products")
}

model Category {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  products    Product[]

  @@index([companyId])
  @@map("categories")
}

model Supplier {
  id        String    @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  taxId     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relaciones
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([companyId])
  @@map("suppliers")
}

model Customer {
  id        String    @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relaciones
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales           Sale[]
  invoices        Invoice[]
  loyaltyPoints   LoyaltyPoint[]

  @@index([companyId])
  @@unique([id, companyId])
  @@map("customers")
}

model Sale {
  id           String        @id @default(uuid())
  companyId    String
  storeId      String
  customerId   String?
  userId       String
  invoiceNumber String?
  total        Decimal       @db.Decimal(10, 2)
  subtotal     Decimal       @db.Decimal(10, 2)
  tax          Decimal       @db.Decimal(10, 2)
  discount     Decimal?      @db.Decimal(10, 2)
  status       SaleStatus    @default(COMPLETED)
  paymentMethod PaymentMethod?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relaciones
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId, companyId], references: [id, companyId], onDelete: Cascade)
  customer      Customer?    @relation(fields: [customerId, companyId], references: [id, companyId])
  user          User         @relation(fields: [userId], references: [id])
  items         SaleItem[]
  loyaltyPoints LoyaltyPoint[]

  @@unique([companyId, invoiceNumber])
  @@unique([id, companyId])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, storeId, createdAt(sort: Desc)])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  discount  Decimal? @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)

  // Relaciones
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

/// Factura emitida o pendiente de cobro. Fuente de verdad para recordatorios de vencimiento.
model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  customerId      String?
  createdByUserId String
  invoiceNumber   String?
  status          InvoiceStatus @default(DRAFT)
  total           Decimal       @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)
  tax             Decimal       @db.Decimal(10, 2)
  discount        Decimal?      @db.Decimal(10, 2)
  dueDate         DateTime?
  issueDate       DateTime      @default(now())
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId, companyId], references: [id, companyId])
  createdByUser   User          @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([companyId, invoiceNumber])
  @@unique([id, companyId])
  @@index([companyId, dueDate])
  @@index([companyId, status])
  @@map("invoices")
}

model StoreConfig {
  id                    String   @id @default(uuid())
  companyId             String
  name                  String
  address               String?
  phone                 String?
  email                 String?
  taxId                 String?
  currency              String   @default("USD")
  taxRate               Decimal  @db.Decimal(5, 4) @default(0)
  lowStockAlert         Int      @default(10)
  invoicePrefix         String   @default("INV-")
  invoiceNumber         Int      @default(1)
  allowSalesWithoutStock Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@map("store_configs")
}

model Store {
  id        String    @id @default(uuid())
  companyId String
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  taxId     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales     Sale[]
  userStores UserStore[]
  inventory  StoreInventory[]
  inventoryTransfersFrom InventoryTransfer[] @relation("InventoryTransferFrom")
  inventoryTransfersTo   InventoryTransfer[] @relation("InventoryTransferTo")
  ticketConfigs TicketConfig[]

  @@index([companyId])
  @@unique([id, companyId])
  @@map("stores")
}

/// Per-store stock levels. Separates inventory tracking from product catalog
/// so a single product can exist in multiple stores with independent stock.
model StoreInventory {
  id        String   @id @default(uuid())
  companyId String
  storeId   String
  productId String
  quantity  Int      @default(0)
  minStock  Int      @default(0)
  maxStock  Int?
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId, companyId], references: [id, companyId], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@index([companyId, storeId])
  @@map("store_inventory")
}

/// Locales asignados a usuarios con rol USER. OWNER/ADMIN/superuser tienen acceso a todos los locales.
model UserStore {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("user_stores")
}

model TicketConfig {
  id                String     @id @default(uuid())
  companyId         String
  storeId           String?
  ticketType        TicketType @default(TICKET)
  header            String?
  description       String?
  logoUrl           String?
  footer            String?
  defaultPrinterName String?
  thermalWidth      Int        @default(80)
  fontSize          Int        @default(12)
  copies            Int        @default(1)
  autoPrint         Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store       Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  @@map("ticket_configs")
}

model UserPreferences {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  language  String   @default("es")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("user_preferences")
}

model InventoryTransfer {
  id          String        @id @default(uuid())
  companyId   String
  fromStoreId String
  toStoreId   String
  productId   String
  quantity    Int
  notes       String?
  status      TransferStatus @default(PENDING)
  createdById String
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relaciones
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromStore   Store         @relation("InventoryTransferFrom", fields: [fromStoreId, companyId], references: [id, companyId], onDelete: Restrict)
  toStore     Store         @relation("InventoryTransferTo", fields: [toStoreId, companyId], references: [id, companyId], onDelete: Restrict)
  product     Product       @relation(fields: [productId, companyId], references: [id, companyId])
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([companyId, fromStoreId])
  @@index([companyId, toStoreId])
  @@index([companyId, productId])
  @@index([companyId, status])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("inventory_transfers")
}

model LoyaltyConfig {
  id                    String   @id @default(uuid())
  companyId             String
  pointsPerDollar       Decimal  @db.Decimal(10, 2)
  redemptionRate        Decimal  @db.Decimal(10, 4)
  pointsExpireMonths    Int?
  minPurchaseForPoints  Decimal  @db.Decimal(10, 2) @default(0)
  maxPointsPerPurchase   Int?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@map("loyalty_configs")
}

model LoyaltyPoint {
  id          String           @id @default(uuid())
  companyId   String
  customerId  String
  saleId      String?
  points      Int
  type        LoyaltyPointType
  description String?
  expiresAt  DateTime?
  createdAt   DateTime         @default(now())

  // Relaciones
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer         @relation(fields: [customerId, companyId], references: [id, companyId])
  sale        Sale?            @relation(fields: [saleId, companyId], references: [id, companyId])

  @@index([companyId, customerId])
  @@map("loyalty_points")
}

model Notification {
  id          String            @id @default(uuid())
  userId      String
  companyId   String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  title       String
  message     String
  data        Json?             // JSON estructurado
  actionUrl   String?
  status      NotificationStatus @default(UNREAD)
  expiresAt   DateTime?
  readAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relaciones
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([companyId])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  pushEnabled Boolean  @default(true)
  emailEnabled Boolean @default(false)
  inAppEnabled Boolean @default(true)
  preferences Json?    // { type: { inApp: boolean, push: boolean, email: boolean } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ActionHistory {
  id          String     @id @default(uuid())
  companyId   String
  userId      String
  action      ActionType
  entityType  EntityType
  entityId    String?
  details     Json?      // JSON estructurado
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  // Relaciones
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user        User       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([companyId, createdAt(sort: Desc)])
  @@map("action_history")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
