{
  "name": "@multisystem/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/client.js",
  "types": "./dist/src/client.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/client.js",
      "require": "./dist/src/client.js",
      "types": "./dist/src/client.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "prisma",
    "prisma.config.ts",
    "README.md"
  ],
  "scripts": {
    "build": "prisma generate && node scripts/copy-generated-for-tsc.mjs && tsc -p tsconfig.build.json && node scripts/fix-esm-extensions.mjs",
    "generate": "prisma generate",
    "migrate": "cross-env DB_TARGET=prod prisma migrate deploy",
    "migrate:dev": "cross-env DB_TARGET=dev prisma migrate dev",
    "migrate:deploy": "cross-env DB_TARGET=prod prisma migrate deploy",
    "db:push": "cross-env DB_TARGET=prod prisma db push",
    "db:push:dev": "cross-env DB_TARGET=dev prisma db push",
    "db:seed": "cross-env DB_TARGET=prod tsx prisma/seed.ts",
    "db:seed:dev": "cross-env DB_TARGET=dev tsx prisma/seed.ts",
    "db:reset": "cross-env DB_TARGET=prod prisma migrate reset --force",
    "db:reset:dev": "cross-env DB_TARGET=dev prisma migrate reset --force",
    "db:erase": "pnpm db:reset",
    "db:erase:dev": "pnpm db:reset:dev",
    "studio": "cross-env DB_TARGET=dev prisma studio"
  },
  "prisma": {
    "seed": "cross-env DB_TARGET=prod tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.13.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
