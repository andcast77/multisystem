# ---------------------------------------------------
# Local target (Docker / development)
# Used by commands ending in :dev
# ---------------------------------------------------
DATABASE_URL_DEV=postgresql://<LOCAL_USER>:<LOCAL_PASSWORD>@localhost:5432/<LOCAL_DB>
# Optional override for local shadow DB (migrate diff/reset internals)
# SHADOW_DATABASE_URL_DEV=postgresql://<LOCAL_USER>:<LOCAL_PASSWORD>@localhost:5432/<LOCAL_DB_SHADOW>

# ---------------------------------------------------
# Production target (Neon)
# Used by standard commands with no :dev suffix
# ---------------------------------------------------
DATABASE_URL=postgresql://<PROD_USER>:<PROD_PASSWORD>@<PROD_POOLED_HOST>/<PROD_DB>?sslmode=require
# Optional override for production shadow DB
# SHADOW_DATABASE_URL=postgresql://<PROD_USER>:<PROD_PASSWORD>@<PROD_SHADOW_HOST>/<PROD_DB_SHADOW>?sslmode=require

# Optional target selector for scripts.
# prod => DATABASE_URL / SHADOW_DATABASE_URL
# dev => DATABASE_URL_DEV / SHADOW_DATABASE_URL_DEV
# DB_TARGET=prod

# Optional runtime mode for Prisma client logging behavior.
# NODE_ENV=development

# Required by new scripts:
# - prod/default commands => DATABASE_URL
# - :dev commands => DATABASE_URL_DEV
