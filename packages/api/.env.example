# Puerto en el que correrá el servidor API
PORT=<API_PORT>

# Orígenes CORS permitidos (separados por coma)
# Hub (3001), ShopFlow (3003), Workify (3004) y otros frontends
CORS_ORIGIN=<CORS_ORIGINS_COMMA_SEPARATED>

# URL de conexión a PostgreSQL (local Docker)
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# JWT: obligatorio en producción. Genera uno seguro: openssl rand -base64 32
JWT_SECRET=<JWT_SECRET>
JWT_EXPIRES_IN=<JWT_EXPIRES_IN>

# Redis cache opcional (Upstash REST)
# UPSTASH_REDIS_REST_URL=<UPSTASH_REDIS_REST_URL>
# UPSTASH_REDIS_REST_TOKEN=<UPSTASH_REDIS_REST_TOKEN>

# Feature flags opcionales
# ENABLE_API_DOCS=false

# Cookie de sesión: establece en 1 para entornos locales (http).
# Usa SameSite=Lax sin Secure, evitando problemas de borrado de cookies
# en navegadores cuando el hub y la API están en puertos distintos de localhost.
# NO usar en staging/producción (https).
# AUTH_SESSION_INSECURE=1

# Entorno de ejecución
NODE_ENV=<NODE_ENV>

# Detrás de reverse proxy (Nginx, ALB, HAProxy) o en Vercel: confía en X-Forwarded-For / X-Forwarded-Proto
# para que request.ip y @fastify/rate-limit usen el cliente real. El proxy debe enviar esos headers
# (ver Fastify Recommendations — Nginx example).
# Valores: vacío/false | true/1/yes | número 1–32 (saltos de proxy).
# En Vercel suele convenir TRUST_PROXY=1 para no agrupar todo el tráfico bajo una sola IP interna.
TRUST_PROXY=false

# Variables de plataforma/test (normalmente no se definen manualmente)
# VERCEL=1
# VITEST=true

# Smoke load (pnpm run load:smoke; requiere API en marcha)
# LOAD_TEST_URL=http://127.0.0.1:3000
# LOAD_TEST_CONNECTIONS=10
# LOAD_TEST_DURATION=5

# Cifrado de campos sensibles (AES-256-GCM). Genera uno nuevo: openssl rand -base64 32
# Obligatorio en producción/staging/Vercel. Sin esta variable los campos PII no se cifran.
FIELD_ENCRYPTION_KEY=<FIELD_ENCRYPTION_KEY>

# Legacy opcional (no usado por runtime actual)
# DATABASE_API_URL=<DATABASE_API_URL>