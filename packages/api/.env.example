# ---------------------------------------------------
# Copy to packages/api/.env and replace every <PLACEHOLDER>. Do not commit `.env`.
# ---------------------------------------------------

# ---------------------------------------------------
# Server (Fastify listen, CORS, Node)
# ---------------------------------------------------
PORT=<API_PORT>
CORS_ORIGIN=<CORS_ORIGIN_COMMA_SEPARATED>
NODE_ENV=<NODE_ENV>

# ---------------------------------------------------
# PostgreSQL (Prisma / Neon)
# Same contract as packages/database — pooled host in prod with ?sslmode=require
# ---------------------------------------------------
DATABASE_URL=postgresql://<API_DB_USER>:<API_DB_PASSWORD>@<API_DB_HOST>:<API_DB_PORT>/<API_DB_NAME>?sslmode=<SSL_MODE>

# ---------------------------------------------------
# JWT / session (login, refresh cookie, lockout)
# ---------------------------------------------------
JWT_SECRET=<JWT_SIGNING_SECRET>
JWT_ACCESS_EXPIRES_IN=<ACCESS_JWT_TTL>
REFRESH_TOKEN_EXPIRES_IN=<REFRESH_SESSION_TTL>
MAX_LOGIN_ATTEMPTS=<MAX_FAILED_LOGINS>
LOCKOUT_DURATION_MINUTES=<LOCKOUT_MINUTES>
SESSION_LAST_SEEN_THROTTLE_SECONDS=<LAST_SEEN_THROTTLE_SECONDS>

# ---------------------------------------------------
# Redis (Upstash REST) — OTP, cache, queues
# ---------------------------------------------------
UPSTASH_REDIS_REST_URL=https://<UPSTASH_REDIS_ID>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<UPSTASH_REDIS_REST_TOKEN>

# ---------------------------------------------------
# Reverse proxy / TLS (trust X-Forwarded-* on Vercel or behind Nginx)
# Empty, false, true, 1, yes, or hop count 1–32
# En Vercel (VERCEL=1), si omites esta variable, el servidor ya usa trust proxy por defecto.
# ---------------------------------------------------
TRUST_PROXY=<TRUST_PROXY>

# ---------------------------------------------------
# Field encryption (AES-256-GCM, 32-byte key as base64)
# Generate: openssl rand -base64 32
# ---------------------------------------------------
FIELD_ENCRYPTION_KEY=<FIELD_ENCRYPTION_KEY_BASE64>

# ---------------------------------------------------
# MFA TOTP (issuer label in authenticator apps)
# ---------------------------------------------------
MFA_TOTP_ISSUER=<MFA_TOTP_ISSUER>

# ---------------------------------------------------
# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# ---------------------------------------------------
VAPID_SUBJECT=mailto:<VAPID_CONTACT_EMAIL>
VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>
VAPID_PRIVATE_KEY=<VAPID_PRIVATE_KEY>

# ---------------------------------------------------
# Company registration (Turnstile, OTP pepper, registration ticket JWT)
# ---------------------------------------------------
# Cloudflare: site key (NEXT_PUBLIC_* en Hub/Shopflow/Workify) y este secret deben ser del MISMO widget.
# Claves de PRUEBA (cualquier dominio): sitekey visible 1x00000000000000000000AA + secret 1x0000000000000000000000000000000AA
#   https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# IMPORTANTE: un secret de PRODUCCIÓN rechaza tokens emitidos con sitekey de prueba (XXXX.DUMMY.TOKEN.XXXX).
# Producción: widget en Cloudflare, hostname permitido (p. ej. tu dominio o el preview *.vercel.app).
#   Misma site key en apps Next (NEXT_PUBLIC_TURNSTILE_SITE_KEY) y este secret en el API.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
OTP_PEPPER=<OTP_PEPPER>
# Optional; if unset at runtime, JWT_SECRET is used
REGISTRATION_TICKET_SECRET=<REGISTRATION_TICKET_SECRET>
REGISTRATION_TICKET_EXPIRES_IN=<REGISTRATION_TICKET_TTL>
OTP_CHALLENGE_TTL_SECONDS=<OTP_CHALLENGE_TTL_SECONDS>
# Pre-registration email OTP (PLAN-39). Default off — product uses magic link only (PLAN-40).
# Set to true, 1, or yes to expose POST /v1/auth/register/otp/send|verify.
REGISTRATION_OTP_ENABLED=false

# ---------------------------------------------------
# Email transaccional (Resend)
# ---------------------------------------------------
# API key: https://resend.com/api-keys — docs: https://resend.com/docs/api-reference/emails/send-email
# MAIL_FROM: dominio verificado en Resend, o en pruebas p. ej. "Acme <onboarding@resend.dev>".
# Producción: verificar dominio en Resend y usar From de ese dominio.
RESEND_API_KEY=<RESEND_API_KEY>
MAIL_FROM=<MAIL_FROM>
# URL pública del Hub (enlaces magic link por defecto). Workify/Shopflow envían verificationBaseUrl
# desde el navegador; debe coincidir con un origen listado en CORS_ORIGIN.
HUB_PUBLIC_URL=<HUB_PUBLIC_URL>

# ---------------------------------------------------
# Optional — local http cookies (Hub vs API on different ports). Do not use in prod.
# ---------------------------------------------------
AUTH_SESSION_INSECURE=<AUTH_SESSION_INSECURE>

# ---------------------------------------------------
# Optional — expose OpenAPI UI on /v1/docs in production (controlled environments only)
# ---------------------------------------------------
ENABLE_API_DOCS=<ENABLE_API_DOCS>

# ---------------------------------------------------
# Internal cron (GET /v1/internal/cron/*) — Authorization: Bearer <CRON_SECRET>
# ---------------------------------------------------
CRON_SECRET=<CRON_SECRET>
