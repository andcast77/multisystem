# Variables de Entorno para Render.com
# Copia estas variables al dashboard de Render en la sección "Environment"

# Puerto (Render lo asigna automáticamente, pero puedes dejarlo)
PORT=<RENDER_PORT>

# Orígenes CORS permitidos (separados por coma)
# IMPORTANTE: Reemplaza con las URLs reales de tus frontends desplegados
# Ejemplo para producción:
CORS_ORIGIN=<CORS_ORIGINS_COMMA_SEPARATED>

# URL de conexión a Neon PostgreSQL
# IMPORTANTE: Usa la URL con -pooler para mejor rendimiento en serverless
# Obtén esta URL desde: https://console.neon.tech → Tu proyecto → Connection Details
# Formato: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<POOLED_HOST>/<DB_NAME>?sslmode=require

# URL directa sin pooler para Prisma CLI (migrate, db push, introspect, studio)
# Formato: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Esta API no la usa en runtime; mantenla solo si ejecutas Prisma CLI desde este paquete.
# DIRECT_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<UNPOOLED_HOST>/<DB_NAME>?sslmode=require

# JWT: obligatorio en producción. Configura en Render como Secret File o Environment.
# Genera un secreto seguro: openssl rand -base64 32
JWT_SECRET=<JWT_SECRET>
JWT_EXPIRES_IN=<JWT_EXPIRES_IN>

# Redis cache opcional (Upstash REST)
# UPSTASH_REDIS_REST_URL=<UPSTASH_REDIS_REST_URL>
# UPSTASH_REDIS_REST_TOKEN=<UPSTASH_REDIS_REST_TOKEN>

# Feature flags opcionales
# ENABLE_API_DOCS=false
# AUTH_SESSION_INSECURE=0

# Entorno de ejecución
NODE_ENV=<NODE_ENV>

# Variables de plataforma/test (Render define sus propias vars de entorno)
# VERCEL=1
# VITEST=true

# Legacy opcional (no usado por runtime actual)
# DATABASE_API_URL=<DATABASE_API_URL>
