# =============================================================================
# Multisystem — Docker Compose Environment Variables
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Stack ---
STACK_NAME=multisystem
NETWORK_NAME=multisystem-caddy-network

# --- Postgres ---
POSTGRES_USER=multisystem
POSTGRES_PASSWORD=multisystem
POSTGRES_DB=multisystem
DATABASE_URL=postgresql://multisystem:multisystem@postgres:5432/multisystem

# --- API ---
JWT_SECRET=change-me-to-a-random-secret
FIELD_ENCRYPTION_KEY=change-me-to-a-32-char-base64-key
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# --- Next.js apps ---
NEXT_PUBLIC_API_URL=http://api:3000
API_INTERNAL_URL=http://api:3000
NODE_ENV=production

# Public URLs per app (these must be reachable from the browser)
HUB_URL=http://localhost:3001
SHOPFLOW_URL=http://localhost:3002
WORKIFY_URL=http://localhost:3003
TECHSERVICES_URL=http://localhost:3004
BALANCE_URL=http://localhost:3005
BARO_URL=http://localhost:3006

# Caddy domains (override in production .env)
API_DOMAIN=api.multisystem.app
HUB_DOMAIN=hub.multisystem.app
BARO_DOMAIN=forms.baroconstruccionessrl.com.ar
WORKIFY_DOMAIN=rrhh.baroconstruccionessrl.com.ar
SHOPFLOW_DOMAIN=pos.baroconstruccionessrl.com.ar
TECHSERVICES_DOMAIN=techservices.multisystem.app
BALANCE_DOMAIN=balance.multisystem.app
