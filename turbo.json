{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": [
    "AUTH_SESSION_INSECURE",
    "FIELD_ENCRYPTION_KEY",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_HUB_URL",
    "NEXT_PUBLIC_SHOPFLOW_URL",
    "NEXT_PUBLIC_WORKIFY_URL",
    "NEXT_PUBLIC_TECHSERVICES_URL",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "JWT_ACCESS_EXPIRES_IN",
    "CORS_ORIGIN",
    "NODE_ENV",
    "DB_TARGET",
    "SESSION_LAST_SEEN_THROTTLE_SECONDS"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "generated/**"
      ],
      "env": [
        "AUTH_SESSION_INSECURE",
        "FIELD_ENCRYPTION_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "cache": false
    }
  }
}