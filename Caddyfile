# Caddy reverse proxy — multisystem stack domain routing
# TLS is automatic via Let's Encrypt (Caddy default).
# Usage: docker compose up -d

api.multisystem.app {
    reverse_proxy api:3000
}

forms.baroconstruccionessrl.com.ar {
    reverse_proxy baro:3006
}

rrhh.baroconstruccionessrl.com.ar {
    reverse_proxy workify:3003
}

pos.baroconstruccionessrl.com.ar {
    reverse_proxy shopflow:3002
}

hub.multisystem.app {
    reverse_proxy hub:3001
}

techservices.multisystem.app {
    reverse_proxy techservices:3004
}

balance.multisystem.app {
    reverse_proxy balance:3005
}
