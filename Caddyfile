# Caddy reverse proxy — multisystem stack domain routing
# TLS is automatic via Let's Encrypt (Caddy default).
# Usage: docker compose up -d

{$API_DOMAIN:api.multisystem.app} {
    reverse_proxy api:3000
}

{$BARO_DOMAIN:forms.baroconstruccionessrl.com.ar} {
    reverse_proxy baro:3006
}

{$WORKIFY_DOMAIN:rrhh.baroconstruccionessrl.com.ar} {
    reverse_proxy workify:3003
}

{$SHOPFLOW_DOMAIN:pos.baroconstruccionessrl.com.ar} {
    reverse_proxy shopflow:3002
}

{$HUB_DOMAIN:hub.multisystem.app} {
    reverse_proxy hub:3001
}

{$TECHSERVICES_DOMAIN:techservices.multisystem.app} {
    reverse_proxy techservices:3004
}

{$BALANCE_DOMAIN:balance.multisystem.app} {
    reverse_proxy balance:3005
}
