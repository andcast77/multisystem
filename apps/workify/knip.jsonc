{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  // Next app: Next plugin provides route entry discovery; keep Knip scoped
  // to source to reduce unused-file false positives.
  "project": [
    "src/**/*",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx"
  ]
}
