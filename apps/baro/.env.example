# Baro app — central API auth (Option B)
# cp apps/baro/.env.example apps/baro/.env

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_HUB_URL=http://localhost:3001
# Server-side fetch inside Docker Compose (browser still uses NEXT_PUBLIC_API_URL)
API_INTERNAL_URL=http://api:3000

# Next.js / product
NEXT_PUBLIC_EXPEDIENTE_OUTPUT_SCOPE=sanjuan

# Server Actions (optional — comma-separated origins)
SERVER_ACTIONS_ALLOWED_ORIGINS=http://localhost:3006

# Preview
EXPEDIENTE_PREVIEW_ETAG_REVISION=1
