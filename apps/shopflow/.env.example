# Shopflow (Vite)
# Copy this file to apps/shopflow/.env and adjust values per environment.

# Base URL of the central API consumed by Shopflow.
VITE_API_URL=

# Legacy fallback for compatibility with older environments.
NEXT_PUBLIC_API_URL=

# Optional public VAPID key for browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Runtime mode for local development or production builds.
NODE_ENV=
