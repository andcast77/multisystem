# Shopflow (Vite)
# Copy this file to apps/shopflow/.env and adjust values per environment.

# Base URL of the central API consumed by Shopflow (primary key used by current client code).
VITE_API_URL=<API_BASE_URL>

# Hub base URL (links when Shopflow is inactive or for owner actions). Dev default: http://localhost:3001
VITE_HUB_URL=<HUB_APP_URL>

# Optional public VAPID key for browser push notifications.
VITE_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# Note: server-only vars (VAPID private keys, DB URLs, JWT) must live in backend/API, not Shopflow frontend.
