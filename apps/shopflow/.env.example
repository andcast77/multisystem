# Shopflow (Vite)
# Copy this file to apps/shopflow/.env and adjust values per environment.

# Base URL of the central API consumed by Shopflow (primary key used by current client code).
VITE_API_URL=<API_BASE_URL>

# Legacy fallback for older server/shared paths.
# NEXT_PUBLIC_API_URL=<API_BASE_URL>

# Optional public VAPID key for browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# Optional server-side push notification config.
# VAPID_PRIVATE_KEY=<VAPID_PRIVATE_KEY>
# VAPID_SUBJECT=mailto:admin@shopflow.com

# Optional server-side backup and DB utilities.
# BACKUP_DIR=./backups
# DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# Optional JWT settings for server-side token helpers.
# JWT_SECRET=<JWT_SECRET>
# JWT_EXPIRES_IN=7d

# Runtime mode for local development or production builds.
NODE_ENV=<NODE_ENV>
