# Shopflow (Next.js)
# Copy this file to apps/shopflow/.env.local and adjust values per environment.

# Base URL of the central API consumed by Shopflow.
NEXT_PUBLIC_API_URL=<API_BASE_URL>

# Hub base URL (links when Shopflow is inactive or for owner actions). Dev default: http://localhost:3001
NEXT_PUBLIC_HUB_URL=<HUB_APP_URL>

# Optional public VAPID key for browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# Note: server-only vars (VAPID private keys, DB URLs, JWT) must live in backend/API, not Shopflow frontend.

# Public URLs of sibling apps (landing module cards / footer). Dev defaults: Hub 3001, Shopflow 3002, Workify 3003, Techservices 3004.
NEXT_PUBLIC_SHOPFLOW_URL=<SHOPFLOW_APP_URL>
NEXT_PUBLIC_WORKIFY_URL=<WORKIFY_APP_URL>
NEXT_PUBLIC_TECHSERVICES_URL=<TECHSERVICES_APP_URL>
