# Techservices (Next.js)
# Copy this file to apps/techservices/.env and adjust values per environment.

# Base URL of the central API consumed by Techservices.
NEXT_PUBLIC_API_URL=<API_BASE_URL>

# Optional runtime mode override.
# NODE_ENV=development

# Public URLs for landing page links (sibling apps). Defaults match local dev ports.
NEXT_PUBLIC_HUB_URL=http://localhost:3001
NEXT_PUBLIC_SHOPFLOW_URL=http://localhost:3002
NEXT_PUBLIC_WORKIFY_URL=http://localhost:3003
NEXT_PUBLIC_TECHSERVICES_URL=http://localhost:3004
