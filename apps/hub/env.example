# --- Hub (Vite) — copiar a .env en apps/hub ---
# VITE_API_URL=http://localhost:3000
# VITE_SHOPFLOW_URL=http://localhost:3002
# VITE_WORKIFY_URL=http://localhost:3003
# VITE_TECHSERVICES_URL=http://localhost:3004

# Database Configuration - Neon
# Obtén tu connection string desde: https://console.neon.tech
# Formato: postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require&channel_binding=require

# API Port
API_PORT=3001

# Database API Service Port
DATABASE_API_PORT=3002
DATABASE_API_URL=http://database:3002

# Frontend Ports
HUB_FRONTEND_PORT=3001
SHOPFLOW_FRONTEND_PORT=3002
WORKIFY_FRONTEND_PORT=3003

# CORS Origins (comma-separated) - orígenes de desarrollo permitidos en la API
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# API URL for Frontends
NEXT_PUBLIC_API_URL=http://api:3001

# Database API - Gestión de base de datos (usada internamente por API Principal)
DATABASE_API_URL=http://database:3002

# URLs de módulos frontend (HTTP)
NEXT_PUBLIC_SHOPFLOW_URL=http://shopflow-frontend:3003
NEXT_PUBLIC_WORKIFY_URL=http://workify-frontend:3004

# Node Environment
NODE_ENV=development

