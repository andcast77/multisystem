# Hub (Vite)
# Copy this file to apps/hub/.env and adjust values per environment.

# Base URL of the central API consumed by Hub.
VITE_API_URL=<API_BASE_URL>

# Public URL for Shopflow module navigation from Hub.
VITE_SHOPFLOW_URL=<SHOPFLOW_APP_URL>

# Public URL for Workify module navigation from Hub.
VITE_WORKIFY_URL=<WORKIFY_APP_URL>

# Public URL for Techservices module navigation from Hub.
VITE_TECHSERVICES_URL=<TECHSERVICES_APP_URL>

# Legacy Next.js dashboard fallback (optional).
# Only used by src/app/(dashboard)/page.tsx while that route exists.
# NEXT_PUBLIC_WORKIFY_URL=<WORKIFY_APP_URL>
# NEXT_PUBLIC_SHOPFLOW_URL=<SHOPFLOW_APP_URL>
# NEXT_PUBLIC_TECHSERVICES_URL=<TECHSERVICES_APP_URL>
