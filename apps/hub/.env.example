# Hub (Next.js)
# Copy this file to apps/hub/.env and adjust values per environment.

# Central API base URL. Leave empty in local dev to use same-origin `/v1` via Next rewrites (no CORS).
# Set to an absolute URL (e.g. http://localhost:3000) only if you need direct cross-origin calls.
NEXT_PUBLIC_API_URL=

# Public URLs for module navigation from Hub (dashboard cards).
NEXT_PUBLIC_SHOPFLOW_URL=<SHOPFLOW_APP_URL>
NEXT_PUBLIC_WORKIFY_URL=<WORKIFY_APP_URL>
NEXT_PUBLIC_TECHSERVICES_URL=<TECHSERVICES_APP_URL>
